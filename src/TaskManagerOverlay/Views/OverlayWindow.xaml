<Window x:Class="TaskManagerOverlay.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskManagerOverlay.ViewModels"
        xmlns:views="clr-namespace:TaskManagerOverlay.Views"
        Title="Task Manager Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Visibility="Hidden">
    <Window.Resources>
        <views:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <views:InverseBooleanConverter x:Key="InverseBool"/>
        <views:SuspendResumeLabelConverter x:Key="SuspendLabel"/>
        <views:NullableGpuPercentConverter x:Key="GpuPercentText"/>
        <views:CountToVisibilityConverter x:Key="CountToVis"/>
        <views:PercentToHeatBrushConverter x:Key="HeatBrush"/>

        <!-- Core palette: a soft indigo-blue accent against a layered charcoal surface. -->
        <SolidColorBrush x:Key="AccentBrush" Color="#4E8CFF"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5B94FF" Offset="0"/>
            <GradientStop Color="#7B5CFA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EA5459" Offset="0"/>
            <GradientStop Color="#C4373C" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#5FCF6E" Offset="0"/>
            <GradientStop Color="#3DA34A" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F2262626" Offset="0"/>
            <GradientStop Color="#F2151515" Offset="1"/>
        </LinearGradientBrush>
        <DropShadowEffect x:Key="PanelShadow" Color="#000000" BlurRadius="46" ShadowDepth="0" Opacity="0.55"/>

        <!-- Flat, minimal scrollbar: no arrow buttons, thin translucent track, accent thumb on hover/drag. -->
        <Style x:Key="OverlayScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#40FFFFFF" CornerRadius="4" Margin="2,2" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#70FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OverlayScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource OverlayScrollBarPageButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource OverlayScrollBarPageButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource OverlayScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProcessRowContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AccentBar" Grid.Column="0" Background="{StaticResource AccentBrush}"
                                    CornerRadius="2" Margin="0,5" Opacity="0"/>
                            <Border x:Name="RowBorder" Grid.Column="1" Background="#12FFFFFF" CornerRadius="8"
                                    Padding="10,9" BorderThickness="1" BorderBrush="Transparent" Margin="5,0,0,0">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#1FFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#4A3D6FE0"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <DataTemplate x:Key="ProcessRowTemplate" DataType="{x:Type vm:ProcessRowViewModel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="84"/>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="84"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="6" Background="#20FFFFFF" VerticalAlignment="Center">
                    <Image Source="{Binding Icon}" Width="17" Height="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding ProcessName}" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="10,0" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" Text="{Binding CpuPercent, StringFormat={}{0:0.0}%}" Style="{StaticResource MetricTextStyle}"
                           Foreground="{Binding CpuPercent, Converter={StaticResource HeatBrush}}"/>
                <TextBlock Grid.Column="3" Text="{Binding RamMb, StringFormat={}{0:0} MB}" Style="{StaticResource MetricTextStyle}" Foreground="#CFCFCF"/>
                <TextBlock Grid.Column="4" Text="{Binding GpuPercent, Converter={StaticResource GpuPercentText}}" Style="{StaticResource MetricTextStyle}"
                           Foreground="{Binding GpuPercent, Converter={StaticResource HeatBrush}}"/>

                <Border Grid.Column="5" Background="#332A1F00" CornerRadius="10" Padding="7,3" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsProtected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#E0A500" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Protected" Foreground="#E0A500" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="6" Content="{Binding IsSuspended, Converter={StaticResource SuspendLabel}}"
                        Command="{Binding DataContext.SuspendResumeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        IsEnabled="{Binding IsProtected, Converter={StaticResource InverseBool}}"
                        Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AccentGradient}"
                        Margin="3,0" Padding="10,5"/>
                <Button Grid.Column="7" Content="Kill"
                        Command="{Binding DataContext.KillCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        IsEnabled="{Binding IsProtected, Converter={StaticResource InverseBool}}"
                        Style="{StaticResource ActionButtonStyle}" Background="{StaticResource DangerGradient}"
                        Margin="3,0" Padding="10,5"/>
            </Grid>
        </DataTemplate>

        <!-- Hint bar glyph styles: small vector-drawn chips standing in for Xbox button glyphs and keyboard keycaps. -->
        <Style x:Key="RoundGlyphStyle" TargetType="Border">
            <Setter Property="Width" Value="17"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="CornerRadius" Value="8.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SquareGlyphStyle" TargetType="Border">
            <Setter Property="Width" Value="17"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ShoulderGlyphStyle" TargetType="Border">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#4A4A4A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Wraps a hint chip's glyph+label in a real clickable button while keeping the same
             flat, chip-like look - transparent by default, a faint highlight on hover, and a
             dimmed look when the underlying command can't run (e.g. no row selected). -->
        <Style x:Key="HintButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HintBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HintBorder" Property="Background" Value="#1FFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="HintBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlyphLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="KeyCapStyle" TargetType="Border">
            <Setter Property="Background" Value="#332C2C2C"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="KeyCapTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PlusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="3,0"/>
        </Style>
        <Style x:Key="HintLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0,12,0"/>
        </Style>
        <Style x:Key="HintDividerStyle" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Margin" Value="3,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- Full-screen dark scrim behind the panel; also doubles as a click-off-to-close catcher
         (the MouseLeftButtonDown handler only reacts when the click lands directly on the scrim
         itself, not on any descendant of the panel - see OnScrimMouseLeftButtonDown). -->
    <Grid Background="#A6000000" MouseLeftButtonDown="OnScrimMouseLeftButtonDown">
    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="16" Padding="24"
            Background="{StaticResource PanelBackgroundBrush}" Width="980" Height="766"
            Effect="{StaticResource PanelShadow}"
            HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="9" Background="{StaticResource AccentGradient}" VerticalAlignment="Center">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="Task Manager Overlay" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Foreground="#8C8C8C" FontSize="11" Margin="0,2,0,0">
                            <Run Text="{Binding ActiveRowsView.Count, Mode=OneWay}"/>
                            <Run Text=" processes running"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Width="240" Height="34" CornerRadius="17" Background="#26FFFFFF" BorderThickness="1" VerticalAlignment="Center">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#3A3A3A"/>
                    </Border.BorderBrush>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#8C8C8C"
                                   Margin="12,0,4,0" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="0,4,12,4" Background="Transparent" Foreground="White"
                                     BorderThickness="0" CaretBrush="White" FocusVisualStyle="{x:Null}"/>
                            <TextBlock Text="Filter processes..." Foreground="#777777"
                                       VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>
                <Button Grid.Column="2" Content="&#x2715;" Click="OnCloseButtonClick"
                        ToolTip="Close (hides to tray or exits, depending on the tray icon's 'Close to Tray' setting)"
                        Style="{StaticResource ActionButtonStyle}" Background="#33FFFFFF"
                        Width="28" Height="28" Padding="0" Margin="12,0,0,0" FontSize="12"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#14FFFFFF" CornerRadius="10" Padding="14,10" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuPercent, StringFormat={}{0:0}%}" FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Margin="0,3,0,0"
                                   Foreground="{Binding CpuPercent, Converter={StaticResource HeatBrush}}"/>
                        <Viewbox Stretch="Fill" Height="26" Margin="0,8,0,0">
                            <Grid>
                                <Polygon Points="{Binding CpuHistoryFillPoints}"
                                         Fill="{Binding CpuPercent, Converter={StaticResource HeatBrush}, ConverterParameter=Fill}"/>
                                <Polyline Points="{Binding CpuHistoryPoints}" StrokeThickness="2"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding CpuPercent, Converter={StaticResource HeatBrush}}"/>
                            </Grid>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#14FFFFFF" CornerRadius="10" Padding="14,10" Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="MEMORY" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding RamSummaryText}" FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Margin="0,3,0,0"
                                   Foreground="{Binding RamUsedPercent, Converter={StaticResource HeatBrush}}"/>
                        <Viewbox Stretch="Fill" Height="26" Margin="0,8,0,0">
                            <Grid>
                                <Polygon Points="{Binding RamHistoryFillPoints}"
                                         Fill="{Binding RamUsedPercent, Converter={StaticResource HeatBrush}, ConverterParameter=Fill}"/>
                                <Polyline Points="{Binding RamHistoryPoints}" StrokeThickness="2"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding RamUsedPercent, Converter={StaticResource HeatBrush}}"/>
                            </Grid>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#14FFFFFF" CornerRadius="10" Padding="14,10" Margin="6,0,6,0">
                    <StackPanel>
                        <TextBlock Text="GPU" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding GpuPercent, Converter={StaticResource GpuPercentText}}" FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Margin="0,3,0,0"
                                   Foreground="{Binding GpuPercent, Converter={StaticResource HeatBrush}}"/>
                        <Viewbox Stretch="Fill" Height="26" Margin="0,8,0,0">
                            <Grid>
                                <Polygon Points="{Binding GpuHistoryFillPoints}"
                                         Fill="{Binding GpuPercent, Converter={StaticResource HeatBrush}, ConverterParameter=Fill}"/>
                                <Polyline Points="{Binding GpuHistoryPoints}" StrokeThickness="2"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding GpuPercent, Converter={StaticResource HeatBrush}}"/>
                            </Grid>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#14FFFFFF" CornerRadius="10" Padding="14,10" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="PROCESSES" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ProcessCount}" FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Foreground="White" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" BorderBrush="#26FFFFFF" BorderThickness="0,0,0,1" Margin="9,0,9,8" Padding="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="84"/>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="84"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="PROCESS" Foreground="#787878" FontSize="10" FontWeight="Bold" Margin="10,0"/>
                    <TextBlock Grid.Column="2" Text="CPU" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#787878"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSortedByCpu}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="3" Text="RAM" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#787878"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSortedByRam}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="4" Text="GPU" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#787878"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSortedByGpu}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="6" Grid.ColumnSpan="2" Text="ACTIONS" Foreground="#787878" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <ListBox Grid.Row="3" x:Name="ProcessListBox"
                     ItemsSource="{Binding ActiveRowsView}"
                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ItemContainerStyle="{StaticResource ProcessRowContainerStyle}"
                     ItemTemplate="{StaticResource ProcessRowTemplate}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="False"/>

            <Grid Grid.Row="4" Margin="0,8,0,0"
                  Visibility="{Binding SuspendedRowsView.Count, Converter={StaticResource CountToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,8">
                    <Border Background="#26E0A500" CornerRadius="10" Padding="8,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#E0A500" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Foreground="#E0A500" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Text="SUSPENDED"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding SuspendedRowsView.Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ListBox Grid.Row="1" x:Name="SuspendedListBox"
                         ItemsSource="{Binding SuspendedRowsView}"
                         SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         MaxHeight="150"
                         ItemContainerStyle="{StaticResource ProcessRowContainerStyle}"
                         ItemTemplate="{StaticResource ProcessRowTemplate}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="False"/>
            </Grid>

            <Border Grid.Row="5" BorderBrush="#26FFFFFF" BorderThickness="0,1,0,0" Margin="0,12,0,0" Padding="0,10,0,0">
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Style="{StaticResource SquareGlyphStyle}">
                        <TextBlock Text="+" FontSize="12" Style="{StaticResource GlyphLabelStyle}"/>
                    </Border>
                    <Border Width="17" Height="17" CornerRadius="8.5" Background="#4A4A4A" Margin="3,0,0,0" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#CFCFCF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Navigate" Style="{StaticResource HintLabelStyle}"/>
                    <Border Style="{StaticResource HintDividerStyle}"/>

                    <Button Style="{StaticResource HintButtonStyle}"
                            Command="{Binding SuspendResumeCommand}"
                            ToolTip="Suspend or resume the selected process">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource RoundGlyphStyle}" Background="{StaticResource SuccessGradient}">
                                <TextBlock Text="A" Style="{StaticResource GlyphLabelStyle}"/>
                            </Border>
                            <TextBlock Text="Suspend / Resume" Style="{StaticResource HintLabelStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource HintButtonStyle}"
                            Command="{Binding KillCommand}"
                            ToolTip="Kill the selected process">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource RoundGlyphStyle}" Background="{StaticResource DangerGradient}">
                                <TextBlock Text="X" Style="{StaticResource GlyphLabelStyle}"/>
                            </Border>
                            <TextBlock Text="Kill" Style="{StaticResource HintLabelStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource HintButtonStyle}"
                            Click="OnCloseButtonClick"
                            ToolTip="Close the overlay">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource RoundGlyphStyle}" Background="#4A4A4A">
                                <TextBlock Text="B" Style="{StaticResource GlyphLabelStyle}"/>
                            </Border>
                            <TextBlock Text="Close Overlay" Style="{StaticResource HintLabelStyle}"/>
                        </StackPanel>
                    </Button>
                    <Border Style="{StaticResource HintDividerStyle}"/>

                    <Button Style="{StaticResource HintButtonStyle}"
                            Click="OnFocusSearchHintClick"
                            ToolTip="Focus the search box">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource RoundGlyphStyle}" Background="{StaticResource AccentGradient}">
                                <TextBlock Text="Y" Style="{StaticResource GlyphLabelStyle}"/>
                            </Border>
                            <TextBlock Text="Focus Search" Style="{StaticResource HintLabelStyle}"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource HintButtonStyle}"
                            Click="OnSortPrevHintClick"
                            ToolTip="Sort by previous column">
                        <Border Style="{StaticResource ShoulderGlyphStyle}">
                            <TextBlock Text="LB" FontSize="8" Style="{StaticResource GlyphLabelStyle}"/>
                        </Border>
                    </Button>
                    <Button Style="{StaticResource HintButtonStyle}"
                            Click="OnSortNextHintClick"
                            ToolTip="Sort by next column">
                        <Border Style="{StaticResource ShoulderGlyphStyle}">
                            <TextBlock Text="RB" FontSize="8" Style="{StaticResource GlyphLabelStyle}"/>
                        </Border>
                    </Button>
                    <TextBlock Style="{StaticResource HintLabelStyle}">
                        <Run Text="Sort: "/>
                        <Run Text="{Binding SortMode, Mode=OneWay}"/>
                    </TextBlock>
                    <Border Style="{StaticResource HintDividerStyle}"/>

                    <Button Style="{StaticResource HintButtonStyle}"
                            Click="OnCloseButtonClick"
                            ToolTip="Hide the overlay">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource KeyCapStyle}">
                                <TextBlock Text="Back" Style="{StaticResource KeyCapTextStyle}"/>
                            </Border>
                            <TextBlock Text="+" Style="{StaticResource PlusTextStyle}"/>
                            <Border Style="{StaticResource KeyCapStyle}">
                                <TextBlock Text="Start" Style="{StaticResource KeyCapTextStyle}"/>
                            </Border>
                            <TextBlock Text="or" Style="{StaticResource HintLabelStyle}" Margin="8,0"/>
                            <Border Style="{StaticResource KeyCapStyle}">
                                <TextBlock Text="Ctrl" Style="{StaticResource KeyCapTextStyle}"/>
                            </Border>
                            <TextBlock Text="+" Style="{StaticResource PlusTextStyle}"/>
                            <Border Style="{StaticResource KeyCapStyle}">
                                <TextBlock Text="Alt" Style="{StaticResource KeyCapTextStyle}"/>
                            </Border>
                            <TextBlock Text="+" Style="{StaticResource PlusTextStyle}"/>
                            <Border Style="{StaticResource KeyCapStyle}">
                                <TextBlock Text="O" Style="{StaticResource KeyCapTextStyle}"/>
                            </Border>
                            <TextBlock Text="Hide" Style="{StaticResource HintLabelStyle}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
    </Grid>
</Window>
