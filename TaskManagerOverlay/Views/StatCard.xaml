<UserControl x:Class="TaskManagerOverlay.Views.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <UserControl.Resources>
        <ResourceDictionary Source="/Themes/OverlayStyles.xaml"/>
    </UserControl.Resources>
    <Border Background="{StaticResource ContainerBackgroundBrush}" CornerRadius="10" Padding="{Binding CardPadding, ElementName=Root}">
        <StackPanel>
            <TextBlock Text="{Binding Label, ElementName=Root}" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
            <TextBlock Text="{Binding ValueText, ElementName=Root}" FontFamily="Consolas"
                       FontSize="{Binding ValueFontSize, ElementName=Root}"
                       FontWeight="Bold" Margin="0,5,0,0"
                       Foreground="{Binding ValueBrush, ElementName=Root}"/>
            <Viewbox Stretch="Fill" Height="{Binding ChartHeight, ElementName=Root}" Margin="0,11,0,0">
                <Grid>
                    <Polygon Points="{Binding HistoryFillPoints, ElementName=Root}"
                             Fill="{Binding FillBrush, ElementName=Root}"/>
                    <Polyline Points="{Binding HistoryPoints, ElementName=Root}" StrokeThickness="2"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Stroke="{Binding StrokeBrush, ElementName=Root}"/>
                </Grid>
            </Viewbox>
        </StackPanel>
    </Border>
</UserControl>
