<Window x:Class="TaskManagerOverlay.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskManagerOverlay.ViewModels"
        xmlns:views="clr-namespace:TaskManagerOverlay.Views"
        xmlns:models="clr-namespace:TaskManagerOverlay.Models"
        Title="Task Manager Overlay"
        Icon="/Assets/AppIcon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Visibility="Visible">
    <Window.Resources>
        <views:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <views:InverseBooleanConverter x:Key="InverseBool"/>
        <views:SuspendResumeLabelConverter x:Key="SuspendLabel"/>
        <views:NullableGpuPercentConverter x:Key="GpuPercentText"/>
        <views:CountToVisibilityConverter x:Key="CountToVis"/>
        <views:PercentToHeatBrushConverter x:Key="HeatBrush"/>

        <!-- Core palette: a soft indigo-blue accent against a layered charcoal surface. -->
        <SolidColorBrush x:Key="AccentBrush" Color="#4E8CFF"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5B94FF" Offset="0"/>
            <GradientStop Color="#7B5CFA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#EA5459" Offset="0"/>
            <GradientStop Color="#C4373C" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#5FCF6E" Offset="0"/>
            <GradientStop Color="#3DA34A" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#CC262626" Offset="0"/>
            <GradientStop Color="#CC151515" Offset="1"/>
        </LinearGradientBrush>
        <DropShadowEffect x:Key="PanelShadow" Color="#000000" BlurRadius="46" ShadowDepth="0" Opacity="0.55"/>

        <!-- Flat, minimal scrollbar: no arrow buttons, thin translucent track, accent thumb on hover/drag. -->
        <Style x:Key="OverlayScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#40FFFFFF" CornerRadius="4" Margin="2,2" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#70FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OverlayScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource OverlayScrollBarPageButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource OverlayScrollBarPageButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource OverlayScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProcessRowContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AccentBar" Grid.Column="0" Background="{StaticResource AccentBrush}"
                                    CornerRadius="2" Margin="0,5" Opacity="0"/>
                            <Border x:Name="RowBorder" Grid.Column="1" Background="#12FFFFFF" CornerRadius="8"
                                    Padding="14,12" BorderThickness="1" BorderBrush="Transparent" Margin="6,0,0,0">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#1FFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#4A3D6FE0"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderThickness="2" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
        </Style>

        <DataTemplate x:Key="ProcessRowTemplate" DataType="{x:Type vm:ProcessRowViewModel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="6" Background="#20FFFFFF" VerticalAlignment="Center">
                    <Image Source="{Binding Icon}" Width="17" Height="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding ProcessName}" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="14,0" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2" Text="{Binding CpuPercent, StringFormat={}{0:0.0}%}" Style="{StaticResource MetricTextStyle}"
                           Foreground="{Binding CpuPercent, Converter={StaticResource HeatBrush}}"/>
                <TextBlock Grid.Column="3" Text="{Binding RamMb, StringFormat={}{0:0} MB}" Style="{StaticResource MetricTextStyle}" Foreground="#CFCFCF"/>
                <TextBlock Grid.Column="4" Text="{Binding GpuPercent, Converter={StaticResource GpuPercentText}}" Style="{StaticResource MetricTextStyle}"
                           Foreground="{Binding GpuPercent, Converter={StaticResource HeatBrush}}"/>
                <TextBlock Grid.Column="5" Text="{Binding ImpactScore, StringFormat={}{0:0.0}}" Style="{StaticResource MetricTextStyle}"
                           Foreground="{Binding ImpactScore, Converter={StaticResource HeatBrush}}"/>

                <Border Grid.Column="6" Background="#332A1F00" CornerRadius="10" Padding="7,3" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsProtected, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#E0A500" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Protected" Foreground="#E0A500" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Flat, chrome-less button used for the CPU/RAM/GPU column headers so clicking one
             sets it as the active sort - visuals come entirely from the header's own TextBlock. -->
        <Style x:Key="SortHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Semi-transparent black frame around the panel, sized so its center cell exactly matches
         the panel's 1020x810. The frame rectangles let the native Acrylic blur-behind show through
         at reduced opacity, dimming the content behind the scrim. Also doubles as a click-off-to-close
         catcher (the MouseLeftButtonDown handler only reacts when the click lands directly on a frame
         rectangle, not on any descendant of the panel - see OnScrimMouseLeftButtonDown).
         The rectangles are fully opaque to block the native Acrylic blur-behind in the surrounding
         area, confining the frosted-glass effect to the transparent panel in the centre cell. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="810"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1020"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Rectangle Grid.Row="0" Grid.ColumnSpan="3" Fill="#44000000" MouseLeftButtonDown="OnScrimMouseLeftButtonDown"/>
        <Rectangle Grid.Row="2" Grid.ColumnSpan="3" Fill="#44000000" MouseLeftButtonDown="OnScrimMouseLeftButtonDown"/>
        <Rectangle Grid.Row="1" Grid.Column="0" Fill="#44000000" MouseLeftButtonDown="OnScrimMouseLeftButtonDown"/>
        <Rectangle Grid.Row="1" Grid.Column="2" Fill="#44000000" MouseLeftButtonDown="OnScrimMouseLeftButtonDown"/>

    <Border Grid.Row="1" Grid.Column="1" BorderBrush="#55FFFFFF" BorderThickness="0" CornerRadius="16" Padding="30"
            Background="#66000000"
            Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="9" Background="{StaticResource AccentGradient}" VerticalAlignment="Center">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="17" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Task Manager Overlay" FontSize="20" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="260" Height="36" CornerRadius="18" Background="#26FFFFFF" BorderThickness="1" VerticalAlignment="Center">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#3A3A3A"/>
                    </Border.BorderBrush>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#8C8C8C"
                                   Margin="12,0,4,0" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="SearchBox"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="0,4,12,4" Background="Transparent" Foreground="White"
                                     BorderThickness="0" CaretBrush="White" FocusVisualStyle="{x:Null}"/>
                            <TextBlock Text="Filter processes..." Foreground="#777777"
                                       VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#14FFFFFF" CornerRadius="10" Padding="18,15" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CpuPercent, StringFormat={}{0:0}%}" FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Margin="0,5,0,0"
                                   Foreground="{Binding CpuPercent, Converter={StaticResource HeatBrush}}"/>
                        <Viewbox Stretch="Fill" Height="26" Margin="0,11,0,0">
                            <Grid>
                                <Polygon Points="{Binding CpuHistoryFillPoints}"
                                         Fill="{Binding CpuPercent, Converter={StaticResource HeatBrush}, ConverterParameter=Fill}"/>
                                <Polyline Points="{Binding CpuHistoryPoints}" StrokeThickness="2"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding CpuPercent, Converter={StaticResource HeatBrush}}"/>
                            </Grid>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#14FFFFFF" CornerRadius="10" Padding="18,15" Margin="8,0,8,0">
                    <StackPanel>
                        <TextBlock Text="MEMORY" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding RamSummaryText}" FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Margin="0,5,0,0"
                                   Foreground="{Binding RamUsedPercent, Converter={StaticResource HeatBrush}}"/>
                        <Viewbox Stretch="Fill" Height="26" Margin="0,11,0,0">
                            <Grid>
                                <Polygon Points="{Binding RamHistoryFillPoints}"
                                         Fill="{Binding RamUsedPercent, Converter={StaticResource HeatBrush}, ConverterParameter=Fill}"/>
                                <Polyline Points="{Binding RamHistoryPoints}" StrokeThickness="2"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding RamUsedPercent, Converter={StaticResource HeatBrush}}"/>
                            </Grid>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#14FFFFFF" CornerRadius="10" Padding="18,15" Margin="8,0,8,0">
                    <StackPanel>
                        <TextBlock Text="GPU" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding GpuPercent, Converter={StaticResource GpuPercentText}}" FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Margin="0,5,0,0"
                                   Foreground="{Binding GpuPercent, Converter={StaticResource HeatBrush}}"/>
                        <Viewbox Stretch="Fill" Height="26" Margin="0,11,0,0">
                            <Grid>
                                <Polygon Points="{Binding GpuHistoryFillPoints}"
                                         Fill="{Binding GpuPercent, Converter={StaticResource HeatBrush}, ConverterParameter=Fill}"/>
                                <Polyline Points="{Binding GpuHistoryPoints}" StrokeThickness="2"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Stroke="{Binding GpuPercent, Converter={StaticResource HeatBrush}}"/>
                            </Grid>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#14FFFFFF" CornerRadius="10" Padding="18,15" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="PROCESSES" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ProcessCount}" FontFamily="Consolas" FontSize="20"
                                   FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Margin mirrors the data rows' effective inset: ListBoxItem's accent-bar column (4) +
                 RowBorder's margin (6) + padding (14) on the left, and RowBorder's padding (14) plus
                 the reserved scrollbar gutter (12, see ProcessListBox below) on the right - otherwise
                 the header text lands a dozen-plus pixels off from the columns it's labeling. -->
            <Border Grid.Row="2" BorderBrush="#26FFFFFF" BorderThickness="0,0,0,1" Margin="24,0,26,10" Padding="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="PROCESS" Foreground="#787878" FontSize="10" FontWeight="Bold" Margin="14,0"/>
                    <Button Grid.Column="2" Style="{StaticResource SortHeaderButtonStyle}" Margin="0,0,14,0"
                            Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static models:ProcessSortMode.Cpu}"
                            ToolTip="Sort by CPU">
                        <TextBlock Text="CPU" FontSize="10" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#787878"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortedByCpu}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource SortHeaderButtonStyle}" Margin="0,0,14,0"
                            Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static models:ProcessSortMode.Ram}"
                            ToolTip="Sort by RAM">
                        <TextBlock Text="RAM" FontSize="10" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#787878"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortedByRam}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="4" Style="{StaticResource SortHeaderButtonStyle}" Margin="0,0,14,0"
                            Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static models:ProcessSortMode.Gpu}"
                            ToolTip="Sort by GPU">
                        <TextBlock Text="GPU" FontSize="10" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#787878"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortedByGpu}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="5" Style="{StaticResource SortHeaderButtonStyle}" Margin="0,0,14,0"
                            Command="{Binding SetSortModeCommand}" CommandParameter="{x:Static models:ProcessSortMode.Impact}"
                            ToolTip="Sort by Impact">
                        <TextBlock Text="IMPACT" FontSize="10" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#787878"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSortedByImpact}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
            </Border>

            <ListBox Grid.Row="3" x:Name="ProcessListBox"
                     ItemsSource="{Binding ActiveRowsView}"
                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                     Background="Transparent" BorderThickness="0"
                     ItemContainerStyle="{StaticResource ProcessRowContainerStyle}"
                     ItemTemplate="{StaticResource ProcessRowTemplate}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Visible"
                     ScrollViewer.CanContentScroll="False"
                     MouseDoubleClick="OnProcessRowDoubleClick"
                     SelectionChanged="OnProcessListSelectionChanged"/>

            <Grid Grid.Row="4" Margin="0,14,0,0"
                  Visibility="{Binding SuspendedRowsView.Count, Converter={StaticResource CountToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6,0,0,10">
                    <Border Background="#26E0A500" CornerRadius="10" Padding="8,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#E0A500" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Foreground="#E0A500" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Text="SUSPENDED"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding SuspendedRowsView.Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ListBox Grid.Row="1" x:Name="SuspendedListBox"
                         ItemsSource="{Binding SuspendedRowsView}"
                         SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         MaxHeight="150"
                         ItemContainerStyle="{StaticResource ProcessRowContainerStyle}"
                         ItemTemplate="{StaticResource ProcessRowTemplate}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="False"
                         MouseDoubleClick="OnProcessRowDoubleClick"
                         SelectionChanged="OnProcessListSelectionChanged"/>
            </Grid>

        </Grid>
    </Border>

    <!-- Per-process action modal: stats for the selected process plus Suspend/Kill/Cancel.
         Its own dark backdrop sits above the main panel; clicking directly on the backdrop
         (not the modal card) cancels, mirroring the outer scrim's click-off-to-close behavior. -->
    <Grid Grid.RowSpan="3" Grid.ColumnSpan="3" Background="#B3000000" Visibility="{Binding IsActionModalOpen, Converter={StaticResource BoolToVis}}"
          MouseLeftButtonDown="OnActionModalScrimMouseLeftButtonDown"
          IsVisibleChanged="OnActionModalVisibleChanged">
        <Border Width="480" Background="{StaticResource PanelBackgroundBrush}" CornerRadius="16" Padding="28"
                BorderBrush="#33FFFFFF" BorderThickness="1" Effect="{StaticResource PanelShadow}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                KeyboardNavigation.DirectionalNavigation="Cycle">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                    <Border Width="36" Height="36" CornerRadius="9" Background="#20FFFFFF" VerticalAlignment="Center">
                        <Image Source="{Binding ActionModalRow.Icon}" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ActionModalRow.ProcessName}" Foreground="White" FontSize="17" FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                            <TextBlock Text="{Binding ActionModalRow.Pid, StringFormat=PID {0}}" Foreground="#777777" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                            <Border Background="#1F4E8CFF" CornerRadius="8" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActionModalRow.ImpactScore, StringFormat=Impact {0:0.0}%}"
                                           Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding ActionModalRow.ExecutablePath}" Foreground="#777777" FontSize="10"
                                   TextTrimming="CharacterEllipsis" MaxWidth="380" Margin="0,2,0,0"
                                   ToolTip="{Binding ActionModalRow.ExecutablePath}"/>
                    </StackPanel>
                </StackPanel>

                <Grid Margin="0,0,0,26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#14FFFFFF" CornerRadius="10" Padding="14,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="CPU" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ActionModalRow.CpuPercent, StringFormat={}{0:0.0}%}" FontFamily="Consolas" FontSize="16"
                                       FontWeight="Bold" Margin="0,5,0,0"
                                       Foreground="{Binding ActionModalRow.CpuPercent, Converter={StaticResource HeatBrush}}"/>
                            <Viewbox Stretch="Fill" Height="24" Margin="0,10,0,0">
                                <Grid>
                                    <Polygon Points="{Binding SelectedProcessCpuHistoryFillPoints}"
                                             Fill="{Binding ActionModalRow.CpuPercent, Converter={StaticResource HeatBrush}, ConverterParameter=Fill}"/>
                                    <Polyline Points="{Binding SelectedProcessCpuHistoryPoints}" StrokeThickness="2"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Stroke="{Binding ActionModalRow.CpuPercent, Converter={StaticResource HeatBrush}}"/>
                                </Grid>
                            </Viewbox>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#14FFFFFF" CornerRadius="10" Padding="14,12" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock Text="RAM" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ActionModalRow.RamMb, StringFormat={}{0:0} MB}" FontFamily="Consolas" FontSize="16"
                                       FontWeight="Bold" Foreground="#CFCFCF" Margin="0,5,0,0"/>
                            <Viewbox Stretch="Fill" Height="24" Margin="0,10,0,0">
                                <Grid>
                                    <Polygon Points="{Binding SelectedProcessRamHistoryFillPoints}" Fill="#224E8CFF"/>
                                    <Polyline Points="{Binding SelectedProcessRamHistoryPoints}" StrokeThickness="2"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Stroke="{StaticResource AccentBrush}"/>
                                </Grid>
                            </Viewbox>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#14FFFFFF" CornerRadius="10" Padding="14,12" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="GPU" Foreground="#888888" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ActionModalRow.GpuPercent, Converter={StaticResource GpuPercentText}}" FontFamily="Consolas" FontSize="16"
                                       FontWeight="Bold" Margin="0,5,0,0"
                                       Foreground="{Binding ActionModalRow.GpuPercent, Converter={StaticResource HeatBrush}}"/>
                            <Viewbox Stretch="Fill" Height="24" Margin="0,10,0,0">
                                <Grid>
                                    <Polygon Points="{Binding SelectedProcessGpuHistoryFillPoints}"
                                             Fill="{Binding ActionModalRow.GpuPercent, Converter={StaticResource HeatBrush}, ConverterParameter=Fill}"/>
                                    <Polyline Points="{Binding SelectedProcessGpuHistoryPoints}" StrokeThickness="2"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Stroke="{Binding ActionModalRow.GpuPercent, Converter={StaticResource HeatBrush}}"/>
                                </Grid>
                            </Viewbox>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="SuspendModalButton" Content="{Binding ActionModalRow.IsSuspended, Converter={StaticResource SuspendLabel}}"
                            Command="{Binding ConfirmSuspendResumeCommand}"
                            IsEnabled="{Binding ActionModalRow.IsProtected, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AccentGradient}"
                            Padding="0,12" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" x:Name="KillModalButton" Content="Kill"
                            Command="{Binding ConfirmKillCommand}"
                            IsEnabled="{Binding ActionModalRow.IsProtected, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource ActionButtonStyle}" Background="{StaticResource DangerGradient}"
                            Padding="0,12" Margin="8,0"/>
                    <Button Grid.Column="2" x:Name="CancelModalButton" Content="Cancel"
                            Command="{Binding CancelActionModalCommand}"
                            Style="{StaticResource ActionButtonStyle}" Background="#3A3A3A"
                            Padding="0,12" Margin="8,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
    </Grid>
</Window>
